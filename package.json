{
  "name": "chorequest",
  "version": "0.8.1",
  "private": true,
  "scripts": {
    "predev": "npm run db:preflight:local",
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "db:preflight:local": "tsx scripts/check-local-supabase-migrations.ts",
    "db:migrate:local": "npx supabase db push --local",
    "db:reset:local": "npx supabase db reset --local",
    "docker:dev": "docker compose up -d postgres redis || echo 'Docker not available - using local development setup'",
    "docker:down": "docker compose down || true",
    "test": "npm run test:unit && npm run test:integration",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest",
    "test:integration": "NODE_NO_WARNINGS=1 jest --config jest.integration.config.js",
    "test:e2e": "playwright test",
    "test:release-pipeline": "jest --runTestsByPath tests/unit/release-pipeline-config.test.ts tests/unit/release-version-metadata.test.ts",
    "release:dry-run": "semantic-release --dry-run --no-ci",
    "version": "npm install --package-lock-only --ignore-scripts && git add package-lock.json"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.544.0",
    "next": "15.5.18",
    "node-cron": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.58.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "jest": "^30.1.1",
    "jest-environment-jsdom": "^30.1.1",
    "jsonwebtoken": "^9.0.2",
    "semantic-release": "^25.0.5",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.5",
    "tsx": "^4.20.5",
    "typescript": "^5",
    "undici": "^7.25.0",
    "whatwg-fetch": "^3.6.20"
  }
}
